PORT=4000
NODE_ENV=production
APP_BASE_URL=YOUR_VALUE_HERE
LOG_LEVEL=info
CORS_ORIGIN=YOUR_VALUE_HERE

DATABASE_URL=postgres://prisma.PROJECT_REF:YOUR_VALUE_HERE@REGION.pooler.supabase.com:5432/postgres?sslmode=require&schema=public

JWT_ACCESS_SECRET=YOUR_VALUE_HERE
JWT_REFRESH_SECRET=YOUR_VALUE_HERE
JWT_STREAM_SECRET=YOUR_VALUE_HERE
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=14d
JWT_STREAM_EXPIRES_IN=60s

REFRESH_TOKEN_COOKIE_NAME=jinro_refresh_token
ACCESS_TOKEN_HEADER_NAME=authorization

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
AUTH_RATE_LIMIT_MAX=20

SSE_HEARTBEAT_INTERVAL_MS=15000
SSE_RETRY_INTERVAL_MS=3000

AI_PROVIDER=stub
AI_API_KEY=YOUR_VALUE_HERE
AI_MODEL_DEFAULT=stub-chat-model
AI_EMBEDDING_MODEL=stub-embedding-model
AI_REQUEST_TIMEOUT_MS=30000

AWS_REGION=YOUR_VALUE_HERE
AWS_S3_BUCKET=YOUR_VALUE_HERE
AWS_SECRETS_PREFIX=YOUR_VALUE_HERE

GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET
GOOGLE_CALLBACK_URL=http://localhost:4000/v1/auth/google/callback

