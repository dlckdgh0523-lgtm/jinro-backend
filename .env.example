PORT=4000
NODE_ENV=production
APP_BASE_URL=YOUR_VALUE_HERE
LOG_LEVEL=info
CORS_ORIGIN=YOUR_VALUE_HERE

DATABASE_URL=postgres://prisma.PROJECT_REF:YOUR_VALUE_HERE@REGION.pooler.supabase.com:5432/postgres?sslmode=require&schema=public

JWT_ACCESS_SECRET=YOUR_VALUE_HERE
JWT_REFRESH_SECRET=YOUR_VALUE_HERE
JWT_STREAM_SECRET=YOUR_VALUE_HERE
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=14d
JWT_STREAM_EXPIRES_IN=60s

REFRESH_TOKEN_COOKIE_NAME=jinro_refresh_token
ACCESS_TOKEN_HEADER_NAME=authorization

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
AUTH_RATE_LIMIT_MAX=20

SSE_HEARTBEAT_INTERVAL_MS=15000
SSE_RETRY_INTERVAL_MS=3000

# AI Configuration
# AI_PROVIDER: "stub" (개발/테스트) 또는 "openai" (운영)
AI_PROVIDER=stub

# OpenAI API Key (AI_PROVIDER=openai일 때 필수)
OPENAI_API_KEY=

# Fallback: AI_API_KEY는 OPENAI_API_KEY 미설정 시 대체 사용
AI_API_KEY=

# AI 모델 설정
# OpenAI mini 계열 모델: gpt-4o-mini, gpt-4-turbo (기본값: gpt-4o-mini)
AI_MODEL_DEFAULT=gpt-4o-mini

# Embedding 모델 설정
# OpenAI 지원 모델: text-embedding-3-small, text-embedding-3-large (기본값: text-embedding-3-small)
AI_EMBEDDING_MODEL=text-embedding-3-small

# OpenAI API 기본 URL (커스텀 프록시/자체 호스팅 시 변경)
OPENAI_BASE_URL=https://api.openai.com/v1

# AI 요청 타임아웃 (ms)
AI_REQUEST_TIMEOUT_MS=30000

AWS_REGION=YOUR_VALUE_HERE
AWS_S3_BUCKET=YOUR_VALUE_HERE
AWS_SECRETS_PREFIX=YOUR_VALUE_HERE

GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET
GOOGLE_CALLBACK_URL=http://localhost:5173/auth/google/callback
