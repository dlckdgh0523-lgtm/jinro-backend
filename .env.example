PORT=4000
NODE_ENV=production
APP_BASE_URL=https://api-staging.example.com
LOG_LEVEL=info
CORS_ORIGIN=https://staging.example.amplifyapp.com

DATABASE_URL=postgresql://jinro_app:replace-me@db.example.internal:5432/jinro_nachimban?schema=app&sslmode=require

JWT_ACCESS_SECRET=replace-with-64-char-access-secret
JWT_REFRESH_SECRET=replace-with-64-char-refresh-secret
JWT_STREAM_SECRET=replace-with-64-char-stream-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=14d
JWT_STREAM_EXPIRES_IN=60s

REFRESH_TOKEN_COOKIE_NAME=jinro_refresh_token
ACCESS_TOKEN_HEADER_NAME=authorization

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
AUTH_RATE_LIMIT_MAX=20

SSE_HEARTBEAT_INTERVAL_MS=15000
SSE_RETRY_INTERVAL_MS=3000

AI_PROVIDER=stub
AI_API_KEY=
AI_MODEL_DEFAULT=stub-chat-model
AI_EMBEDDING_MODEL=stub-embedding-model
AI_REQUEST_TIMEOUT_MS=30000

AWS_REGION=ap-northeast-2
AWS_S3_BUCKET=
AWS_SECRETS_PREFIX=/jinro-nachimban/staging/backend
